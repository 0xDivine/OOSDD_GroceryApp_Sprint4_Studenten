<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Grocery.App.Views.BoughtProductsView"
             Title="Klanten per product">
    <ContentPage.Content>
        <StackLayout Padding="10">
            <Picker Title="Selecteer product"
                    ItemsSource="{Binding Products}"
                    ItemDisplayBinding="{Binding Name}"
                    SelectedItem="{Binding SelectedProduct}"
                    SelectedIndexChanged="Picker_SelectedIndexChanged"/>
            <CollectionView ItemsSource="{Binding BoughtProductsList}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Margin="5" Padding="10">
                            <StackLayout>
                                <Label Text="{Binding Client.Name}" FontAttributes="Bold" FontSize="16"/>
                                <Label Text="{Binding GroceryList.Name}" FontSize="14" TextColor="Gray"/>
                                <Label Text="{Binding Product.Name}" FontSize="13" TextColor="DarkGray"/>
                            </StackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </StackLayout>
    </ContentPage.Content>
</ContentPage>